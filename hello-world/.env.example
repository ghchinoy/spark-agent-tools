# Copy to .env and edit. scripts/deploy.sh sources this file.
# .env is gitignored — never commit real secrets.

# Google Cloud target for deployment
GCP_PROJECT=your-gcp-project-id
GCP_REGION=us-central1
SERVICE_NAME=hello-spark-mcp

# HMAC key used to sign/verify stateless JWT access tokens.
# Generate a strong one: openssl rand -hex 32
# If left blank, scripts/deploy.sh generates a random key for you.
JWT_SIGNING_KEY=

# Local development only: set to "true" to skip JWT verification entirely.
# NEVER set this on a deployed/public instance.
# AUTH_BYPASS=true
